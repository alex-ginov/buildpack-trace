#!/bin/bash
set -e

BUILD_DIR=$1
CACHE_DIR=$2
BUILDPACK_DIR="$(cd -P "$(dirname "$0")/.." && pwd)"

TEMPO_VERSION="2.4.0" # Version de Tempo à installer
NGINX_VERSION="1.24.0" # Version de Nginx à installer

# Nous n'avons pas besoin d'installer des dépendances système
# car nous allons utiliser un binaire nginx précompilé

echo "-----> Installing Tempo v${TEMPO_VERSION}"

# 1. Définir l'URL de téléchargement
TEMPO_ARCHIVE="tempo_${TEMPO_VERSION}_linux_amd64.tar.gz"
TEMPO_URL="https://github.com/grafana/tempo/releases/download/v${TEMPO_VERSION}/${TEMPO_ARCHIVE}"

# Créer les répertoires nécessaires
mkdir -p "$BUILD_DIR/bin"
mkdir -p "$BUILD_DIR/config"
mkdir -p "/tmp/tempo-extract"

# 2. Télécharger et extraire
echo "-----> Downloading Tempo from: $TEMPO_URL"
curl -L --silent --show-error --retry 3 --fail -o "/tmp/$TEMPO_ARCHIVE" "$TEMPO_URL" || \
    (echo "Error downloading Tempo" && exit 1)

echo "-----> Extracting Tempo to /tmp/tempo-extract"
tar -xzf "/tmp/$TEMPO_ARCHIVE" -C "/tmp/tempo-extract"

# 3. Copier les binaires et rendre exécutables
echo "-----> Installing binaries and scripts"
cp /tmp/tempo-extract/tempo "$BUILD_DIR/bin/"
chmod +x "$BUILD_DIR/bin/tempo"

# Installation de Nginx depuis un binaire précompilé
echo "-----> Installing Nginx v${NGINX_VERSION}"
NGINX_BINARY_URL="https://github.com/alex-ginov/nginx-binaries/releases/download/v${NGINX_VERSION}/nginx-linux-amd64"

# Créer les répertoires pour nginx
mkdir -p "$BUILD_DIR/nginx/sbin"
mkdir -p "$BUILD_DIR/nginx/conf"
mkdir -p "$BUILD_DIR/nginx/logs"

# Télécharger le binaire nginx précompilé
echo "Downloading nginx binary from: $NGINX_BINARY_URL"
curl -L --silent --show-error --retry 3 --fail -o "$BUILD_DIR/nginx/sbin/nginx" "$NGINX_BINARY_URL"
chmod +x "$BUILD_DIR/nginx/sbin/nginx"

# Créer le lien symbolique pour nginx dans le PATH
mkdir -p "$BUILD_DIR/bin"
ln -sf "$BUILD_DIR/nginx/sbin/nginx" "$BUILD_DIR/bin/nginx"

# Copier les fichiers de configuration nginx par défaut
mkdir -p "$BUILD_DIR/nginx/conf"
cp -r "/usr/share/nginx/conf/" "$BUILD_DIR/nginx/" || true  # Ne pas échouer si les fichiers n'existent pas

# Copier le script de démarrage depuis le buildpack
cp "$BUILDPACK_DIR/bin/start-tempo" "$BUILD_DIR/bin/"
chmod +x "$BUILD_DIR/bin/start-tempo"

# 4. Copier les configurations par défaut
if [ -f "$BUILDPACK_DIR/config/tempo.yaml" ]; then
  cp "$BUILDPACK_DIR/config/tempo.yaml" "$BUILD_DIR/config/"
fi

if [ -f "$BUILDPACK_DIR/config/nginx.conf" ]; then
  cp "$BUILDPACK_DIR/config/nginx.conf" "$BUILD_DIR/config/"
fi

# Créer les répertoires nécessaires pour nginx
mkdir -p "$BUILD_DIR/nginx/logs"
mkdir -p "$BUILD_DIR/nginx/temp"

# Nettoyage
rm -rf /tmp/tempo-extract /tmp/nginx-*
rm -f "/tmp/$TEMPO_ARCHIVE"

echo "-----> Tempo v${TEMPO_VERSION} and Nginx v${NGINX_VERSION} installed successfully."