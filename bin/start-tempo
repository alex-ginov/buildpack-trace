#!/bin/bash
set -e

# Chemin d'accès racine de l'application
APP_DIR="/app"

# Le chemin des fichiers de configuration dans le slug
TEMPO_CONFIG="${APP_DIR}/config/tempo.yaml"
NGINX_CONFIG="${APP_DIR}/config/nginx.conf"

echo "===== STARTING TEMPO WITH NGINX ====="
echo "PORT: ${PORT}" 

# 1. Vérification des fichiers et du binaire
if [ ! -x "${APP_DIR}/bin/tempo" ]; then
  echo "Error: Tempo binary not found or not executable!" >&2
  exit 1
fi
if [ ! -f "${CONFIG_FILE}" ]; then
  echo "Error: Configuration file ${CONFIG_FILE} not found!" >&2
  exit 1
fi

# 2. Créer les répertoires de stockage dans /tmp/
STORAGE_DIR="/tmp/tempo-data"
mkdir -p "${STORAGE_DIR}/wal"
mkdir -p "${STORAGE_DIR}/blocks"
echo "Storage directories created/verified in ${STORAGE_DIR}"

# 3. Vérifier que les exécutables sont présents
if [ ! -x "${APP_DIR}/nginx/sbin/nginx" ]; then
    echo "Error: nginx is not installed!" >&2
    exit 1
fi

# 4. Lancer Tempo en arrière-plan
echo "-----> Launching Tempo..."
"${APP_DIR}/bin/tempo" \
  --config.file="${TEMPO_CONFIG}" \
  --config.expand-env=true \
  --server.http-listen-port=3200 &

TEMPO_PID=$!

# 5. Attendre que Tempo démarre
echo "Waiting for Tempo to start..."
sleep 5

# 6. Démarrer Nginx
echo "Starting Nginx on port ${PORT}..."
export PORT

# Créer les répertoires temporaires nécessaires pour nginx
mkdir -p "${APP_DIR}/nginx/logs" "${APP_DIR}/nginx/temp"

# Lancer nginx avec le chemin complet
"${APP_DIR}/nginx/sbin/nginx" -p "${APP_DIR}/nginx" -c "${NGINX_CONFIG}"

# Capture des signaux pour arrêt propre
trap 'kill $TEMPO_PID; exit' SIGTERM SIGINT

# Attendre que l'un des processus se termine
wait